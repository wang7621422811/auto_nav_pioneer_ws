        <model name="oval_fence_48"><static>true</static><pose>4.1647 -5.5923 0.0175 0 0 0.8203</pose><link name="link"><visual name="v"><geometry><box><size>0.7667 0.025 0.035</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.9 0.9 0.88 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.7667 0.025 0.035</size></box></geometry></collision></link></model>
        <model name="oval_fence_49"><static>true</static><pose>4.6603 -4.9976 0.0175 0 0 0.9307</pose><link name="link"><visual name="v"><geometry><box><size>0.7823 0.025 0.035</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.9 0.9 0.88 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.7823 0.025 0.035</size></box></geometry></collision></link></model>
        <model name="oval_fence_50"><static>true</static><pose>5.0973 -4.34 0.0175 0 0 1.0368</pose><link name="link"><visual name="v"><geometry><box><size>0.7973 0.025 0.035</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.9 0.9 0.88 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.7973 0.025 0.035</size></box></geometry></collision></link></model>
        <model name="oval_fence_51"><static>true</static><pose>5.4701 -3.6279 0.0175 0 0 1.1392</pose><link name="link"><visual name="v"><geometry><box><size>0.8109 0.025 0.035</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.9 0.9 0.88 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.8109 0.025 0.035</size></box></geometry></collision></link></model>
        <model name="oval_fence_52"><static>true</static><pose>5.7742 -2.8701 0.0175 0 0 1.2384</pose><link name="link"><visual name="v"><geometry><box><size>0.8225 0.025 0.035</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.9 0.9 0.88 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.8225 0.025 0.035</size></box></geometry></collision></link></model>
        <model name="oval_fence_53"><static>true</static><pose>6.0057 -2.0763 0.0175 0 0 1.3352</pose><link name="link"><visual name="v"><geometry><box><size>0.8316 0.025 0.035</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.9 0.9 0.88 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.8316 0.025 0.035</size></box></geometry></collision></link></model>
        <model name="oval_fence_54"><static>true</static><pose>6.1617 -1.2563 0.0175 0 0 1.4301</pose><link name="link"><visual name="v"><geometry><box><size>0.8379 0.025 0.035</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.9 0.9 0.88 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.8379 0.025 0.035</size></box></geometry></collision></link></model>
        <model name="oval_fence_55"><static>true</static><pose>6.2402 -0.4205 0.0175 0 0 1.524</pose><link name="link"><visual name="v"><geometry><box><size>0.8411 0.025 0.035</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.9 0.9 0.88 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.8411 0.025 0.035</size></box></geometry></collision></link></model>

        <!-- ================================================================
             WAYPOINT CONES (orange)  mark the 4 GPS waypoints
             WP1=(2.5, 3.0), WP2=(-3.5, 2.2), WP3=(4.2, -2.8), WP4=(-4.8, -3.5)
             ================================================================ -->
        <model name="waypoint_cone_1">
            <static>true</static>
            <pose>2.5 3.0 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <model name="waypoint_cone_2">
            <static>true</static>
            <pose>-3.5 2.2 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <model name="waypoint_cone_3">
            <static>true</static>
            <pose>4.2 -2.8 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <model name="waypoint_cone_4">
            <static>true</static>
            <pose>-4.8 -3.5 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <!-- ================================================================
             WEAVING CONES (orange)  between WP1 (2.5,3.0) and WP2 (-3.5,2.2)
             5 cones staggered left/right along the WP1->WP2 path.
             Path direction vector: (-6,−0.8), unit≈(-0.991,−0.132)
             Perpendicular: (−0.132, 0.991) → stagger ±0.7m
             Cones at 20%,35%,50%,65%,80% of the path
             ================================================================ -->
        <!-- 20%: base=(1.3, 2.84), offset +0.7 perp -> left -->
        <model name="weave_cone_1">
            <static>true</static>
            <pose>1.207 3.533 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <!-- 35%: base=(0.1, 2.72), offset -0.7 perp -> right -->
        <model name="weave_cone_2">
            <static>true</static>
            <pose>0.192 1.927 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <!-- 50%: base=(-0.5, 2.6), offset +0.7 perp -> left -->
        <model name="weave_cone_3">
            <static>true</static>
            <pose>-0.592 3.293 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <!-- 65%: base=(-1.6, 2.5), offset -0.7 perp -> right -->
        <model name="weave_cone_4">
            <static>true</static>
            <pose>-1.508 1.807 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <!-- 80%: base=(-2.7, 2.36), offset +0.7 perp -> left -->
        <model name="weave_cone_5">
            <static>true</static>
            <pose>-2.792 3.053 0.16 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                    <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>0.95 0.4 0.05 1</diffuse></material>
                </visual>
                <collision name="c">
                    <geometry><cone><radius>0.18</radius><length>0.32</length></cone></geometry>
                </collision>
            </link>
        </model>

        <!-- ================================================================
             COLORED SHAPE OBJECTS one per waypoint, at ~2m from cone
             WP1: red sphere (circle) at (2.5+2, 3.0) = (4.5, 3.0)
             WP2: blue box (square) at (-3.5, 2.2+2) = (-3.5, 4.2)
             WP3: green cylinder at (4.2, -2.8-2) = (4.2, -4.8)
             WP4: yellow sphere at (-4.8-2, -3.5) = (-6.8, -3.5)  adjust inside fence
             ================================================================ -->

        <!-- WP1 colored object: red sphere -->
        <model name="colored_obj_wp1">
            <static>true</static>
            <pose>4.5 3.0 0.3 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><sphere><radius>0.25</radius></sphere></geometry>
                    <material>
                        <ambient>0.9 0.1 0.1 1</ambient>
                        <diffuse>0.85 0.1 0.1 1</diffuse>
                    </material>
                </visual>
                <collision name="c">
                    <geometry><sphere><radius>0.25</radius></sphere></geometry>
                </collision>
            </link>
        </model>

        <!-- WP2 colored object: blue box -->
        <model name="colored_obj_wp2">
            <static>true</static>
            <pose>-3.5 4.2 0.2 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><box><size>0.4 0.4 0.4</size></box></geometry>
                    <material>
                        <ambient>0.1 0.2 0.9 1</ambient>
                        <diffuse>0.1 0.2 0.85 1</diffuse>
                    </material>
                </visual>
                <collision name="c">
                    <geometry><box><size>0.4 0.4 0.4</size></box></geometry>
                </collision>
            </link>
        </model>

        <!-- WP3 colored object: green cylinder -->
        <model name="colored_obj_wp3">
            <static>true</static>
            <pose>4.2 -4.8 0.25 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><cylinder><radius>0.2</radius><length>0.5</length></cylinder></geometry>
                    <material>
                        <ambient>0.1 0.8 0.1 1</ambient>
                        <diffuse>0.1 0.75 0.1 1</diffuse>
                    </material>
                </visual>
                <collision name="c">
                    <geometry><cylinder><radius>0.2</radius><length>0.5</length></cylinder></geometry>
                </collision>
            </link>
        </model>

        <!-- WP4 colored object: yellow box (inside oval, offset inward) -->
        <model name="colored_obj_wp4">
            <static>true</static>
            <pose>-4.8 -1.8 0.2 0 0 0</pose>
            <link name="link">
                <visual name="v">
                    <geometry><box><size>0.35 0.35 0.35</size></box></geometry>
                    <material>
                        <ambient>0.95 0.85 0.1 1</ambient>
                        <diffuse>0.9 0.8 0.1 1</diffuse>
                    </material>
                </visual>
                <collision name="c">
                    <geometry><box><size>0.35 0.35 0.35</size></box></geometry>
                </collision>
            </link>
        </model>

        <!-- Pioneer robot spawn point (west side of oval) -->
        <include>
            <uri>package://auto_nav_pioneer_pkg/urdf/pioneer.urdf</uri>
            <name>pioneer</name>
            <pose>-5.0 0 0.1 0 0 0</pose>
        </include>

    </world>
</sdf>
